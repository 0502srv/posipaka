# ─── Posipaka Configuration ─────────────────────────────────────────────────
# Скопіюйте цей файл як .env та заповніть потрібні значення:
#   cp .env.example .env

# ─── LLM Provider ───────────────────────────────────────────────────────────
# Supported providers: anthropic, openai, ollama, mistral, gemini, groq, deepseek, xai
# Models per provider:
#   anthropic: claude-sonnet-4-20250514, claude-haiku-4-5-20251001, claude-opus-4-20250514
#   openai: gpt-4o, gpt-4o-mini
#   ollama: llama3, mistral (or any local model)
#   mistral: mistral-large-latest, mistral-small-latest
#   gemini: gemini-2.0-flash, gemini-2.5-pro-preview-06-05
#   groq: llama-3.3-70b-versatile, llama-3.1-8b-instant
#   deepseek: deepseek-chat, deepseek-reasoner
#   xai: grok-3, grok-3-mini
LLM_PROVIDER=mistral
LLM_MODEL=mistral-small-latest
LLM_API_KEY=your-api-key-here
# LLM_FALLBACK_PROVIDER=groq
# LLM_FALLBACK_MODEL=llama-3.3-70b-versatile
# LLM_FALLBACK_API_KEY=your-groq-key-here
# LLM_BASE_URL=http://localhost:11434/v1  # Для Ollama
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ─── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_OWNER_ID=0
# TELEGRAM_ALLOWED_USER_IDS=[123456,789012]
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhooks/telegram
# TELEGRAM_USE_WEBHOOK=false

# ─── Discord ────────────────────────────────────────────────────────────────
# DISCORD_TOKEN=your-discord-bot-token
# DISCORD_GUILD_ID=
# DISCORD_CHANNEL_ID=

# ─── Slack ──────────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token

# ─── WhatsApp (Twilio) ─────────────────────────────────────────────────────
# WHATSAPP_ACCOUNT_SID=ACxxxx
# WHATSAPP_AUTH_TOKEN=xxxx
# WHATSAPP_FROM_NUMBER=whatsapp:+14155238886

# ─── Signal ─────────────────────────────────────────────────────────────────
# SIGNAL_PHONE_NUMBER=+380XXXXXXXXX
# SIGNAL_CLI_URL=http://localhost:8080

# ─── Memory ─────────────────────────────────────────────────────────────────
MEMORY_SHORT_TERM_LIMIT=50
MEMORY_CHROMA_ENABLED=true
# MEMORY_ENCRYPT=false

# ─── Security ───────────────────────────────────────────────────────────────
SECURITY_INJECTION_THRESHOLD=0.7
SECURITY_AUDIT_ENABLED=true
SECURITY_MAX_INPUT_LENGTH=8000
SECURITY_APPROVAL_TIMEOUT_SECONDS=300

# ─── Google (Gmail, Calendar) ──────────────────────────────────────────────
# GOOGLE_CREDENTIALS_PATH=~/.posipaka/google_credentials.json
# GOOGLE_TOKEN_PATH=~/.posipaka/google_token.json

# ─── Browser ────────────────────────────────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_BROWSER_TYPE=chromium
BROWSER_TIMEOUT_MS=30000

# ─── Soul (Agent Personality) ──────────────────────────────────────────────
SOUL_NAME=Posipaka
SOUL_LANGUAGE=auto
SOUL_TIMEZONE=Europe/Kyiv

# ─── Web UI ─────────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
# WEB_SECRET_KEY=auto-generated

# ─── Cost Budget ────────────────────────────────────────────────────────────
COST_DAILY_BUDGET_USD=5.0
COST_PER_REQUEST_MAX_USD=0.50
COST_PER_SESSION_MAX_USD=2.0
COST_WARNING_THRESHOLD=0.8

# ─── Enabled Channels ──────────────────────────────────────────────────────
# ENABLED_CHANNELS=["telegram","cli"]
