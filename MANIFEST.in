include README.md
include pyproject.toml
include posipaka/utils/i18n/locale/uk/*.json
include posipaka/utils/i18n/locale/en/*.json

# Exclude dev files from pip package
exclude MASTER.md
exclude CLAUDE.md
recursive-exclude * CLAUDE.md
exclude PLANNING.md
exclude DEV_NOTES.md
recursive-exclude .claude *
recursive-exclude tests *
recursive-exclude docs *
recursive-exclude deploy *

# Editor configs
recursive-exclude .cursor *
recursive-exclude .windsurf *
recursive-exclude .claude *
exclude .cursorrules
exclude .cursorignore
exclude .windsurfrules
exclude .copilot-instructions.md
exclude planning.*
